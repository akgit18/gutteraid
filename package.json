{
  "name": "gutteraid",
  "displayName": "GutterAid",
  "description": "Allow users to define tasks that can be run from icons in the gutter when a regex match is found",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#444444",
    "theme": "dark"
  },
  "publisher": "alek",
  "repository": {
    "type": "git",
    "url": "https://github.com/akgit18/gutteraid.git"
  },
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.59.0"
  },
  "license": "SEE LICENSE IN LICENSE",
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "gutter",
    "gutter icon",
    "gutter button",
    "icon in gutter",
    "task",
    "tasks",
    "task icon",
    "testing",
    "test",
    "tests",
    "run",
    "run icon",
    "run button",
    "play button",
    "play icon",
    "line numbers",
    "side of line numbers"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gutteraid.resetInputs",
        "title": "GutterAid: Reset cached input choices for all tasks"
      },
      {
        "command": "gutteraid.resetInputsForTask",
        "title": "GutterAid: Reset cached input choices"
      }
    ],
    "configuration": {
      "title": "GutterAid",
      "properties": {
        "gutteraid.askForInputsEveryTime": {
          "type": "boolean",
          "default": true,
          "description": "Ask for input values every time tasks are run (if false, cached values are reused)"
        },
        "gutteraid.alertOnError": {
          "type": "boolean",
          "default": false,
          "description": "Show an alert in addition to logging errors/warnings"
        }
      }
    },
    "menus": {
      "testing/item/context": [
        {
          "command": "gutteraid.resetInputsForTask",
          "group": "2_resetInputs@1",
          "when": "testId =~ /^file:.*:.*$/"
        },
        {
          "command": "gutteraid.resetInputs",
          "group": "2_resetInputs@2",
          "when": "testId =~ /^file:.*:.*$/"
        }
      ],
      "testing/item/gutter": [
        {
          "command": "gutteraid.resetInputsForTask",
          "group": "2_resetInputs@1",
          "when": "testId =~ /^file:.*:.*$/"
        },
        {
          "command": "gutteraid.resetInputs",
          "group": "2_resetInputs@2",
          "when": "testId =~ /^file:.*:.*$/"
        }
      ]
    },
    "jsonValidation": [
      {
        "fileMatch": ".gutteraid/patterns.json",
        "url": "./schemas/patterns.schema.json"
      },
      {
        "fileMatch": ".gutteraid/patterns.local.json",
        "url": "./schemas/patterns.local.schema.json"
      }
    ]
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "Malicious authors in an untrusted workspace can modify patterns.json to execute arbitrary code upon click."
    },
    "virtualWorkspaces": {
      "supported": false,
      "description": "Direct file system access and running arbitrary shell commands, both of which this extension uses, may not be available in virtual workspaces."
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "oxlint src --fix --fix-suggestions",
    "lint:check": "oxlint src",
    "fmt": "oxfmt .",
    "test": "vscode-test"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "picomatch": "^4.0.4"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/picomatch": "^4.0.3",
    "@types/vscode": "^1.118.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "typescript": "^6.0.3"
  }
}
